{
  "version": "v6",
  "n_folds": 3,
  "architecture": {
    "backbone": "EfficientNet-B3",
    "pretrained": "ImageNet",
    "img_size": 300,
    "dual_head": "cls + quality_regression",
    "calibration": "Platt Scaling (LogisticRegression on logits)"
  },
  "training": {
    "loss": "FocalLoss(\u03b1=0.75,\u03b3=2.0)+LabelSmoothing(\u03b5=0.05)+MSE(\u03bb=0.3)",
