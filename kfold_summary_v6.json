      "GridDistortion(p=0.2)",
      "RandomGamma(80-120,p=0.3)[NEW v6]",
      "ColorJitter",
      "GaussNoise"
    ],
    "tta": [
      "HFlip",
      "Rotate10",
      "ColorJitter",
      "RandomGamma(90-110,p=0.2)"
    ],
    "tta_n": 5
  },
  "data": {
    "quality_normalization": "(score-1)/9",
    "quality_reject_threshold": 0.278,
    "max_img_per_patient": 8,
